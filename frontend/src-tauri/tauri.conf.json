{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "baynuman",
  "version": "0.1.0",
  "identifier": "com.baynuman.ytdownloaderpro",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "baynuman",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../../bin/ffmpeg.exe",
      "../../bin/ffprobe.exe"
    ],
    "externalBin": [
      "bin/server-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
